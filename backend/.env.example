# Copy to backend/.env (never commit .env)

# Moonshot / Kimi (OpenAI-compatible)
MOONSHOT_API_KEY=sk-your-key-here
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
# Official Moonshot model ids are usually like kimi-k2.5 / kimi-k2.7-code
# If your gateway uses OpenRouter-style names, set e.g. moonshotai/kimi-k2.7-code
KIMI_MODEL=kimi-k2.7-code

# mock | kimi
VISION_MODE=kimi

# Optional later
OXYLABS_USERNAME=
OXYLABS_PASSWORD=
DAYTONA_API_KEY=
NOSANA_API_KEY=

HOST=0.0.0.0
PORT=8000
