# Copy this file to .env.local and add credentials. Never commit real keys.

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEMO_MODE=true

# Daytona sandbox runtime
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us

# Kimi / Moonshot multimodal agent
MOONSHOT_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6

# Nosana GPU jobs
NOSANA_API_KEY=
NOSANA_BASE_URL=https://dashboard.k8s.prd.nos.ci/api

# Qwen3-TTS VoiceDesign service deployed as a Nosana GPU endpoint
NOSANA_TTS_URL=
NOSANA_TTS_BEARER_TOKEN=
TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign
TTS_LANGUAGE=English
TTS_VOICE_DESCRIPTION="Deep, smooth, mature American male voice with a low warm baritone. Confident, unhurried, luxurious, subtly flirtatious, playful, and indulgent, like a charming silver-fox handyman. Reassuring and authoritative during safety instructions. Natural and never cartoonish."
TTS_TIMEOUT_SECONDS=120

# Oxylabs manuals and replacement parts
OXYLABS_USERNAME=
OXYLABS_PASSWORD=
OXYLABS_AI_STUDIO_API_KEY=
OXYLABS_REALTIME_URL=https://realtime.oxylabs.io/v1/queries

# Doubleword safety validator
DOUBLEWORD_API_KEY=
DOUBLEWORD_BASE_URL=https://api.doubleword.ai/v1
DOUBLEWORD_MODEL=Qwen/Qwen3-VL-30B-A3B-Instruct-FP8

# ai& Japan-resident inference
# Copy the exact endpoint and model identifier from the ai& console.
AIAND_API_KEY=
AIAND_BASE_URL=https://api.aiand.com/v1
AIAND_MODEL=moonshotai/kimi-k2.7-code
