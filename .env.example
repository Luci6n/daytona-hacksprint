# Copy to .env or .env.local — NEVER commit real keys.

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
# true = deterministic water-heater fixture (no sponsor spend)
# false = live providers (keys required)
DEMO_MODE=true

# --- Deploy / control plane (operator machine only; not needed inside iOS) ---
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us

# --- Live analysis path A: Moonshot Kimi multimodal ---
MOONSHOT_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6

# --- Live analysis path B: ai& + Doubleword VL (optional alternative) ---
AIAND_API_KEY=
AIAND_BASE_URL=
AIAND_MODEL=moonshotai/kimi-k2.7-code
DOUBLEWORD_API_KEY=
DOUBLEWORD_BASE_URL=https://api.doubleword.ai/v1
DOUBLEWORD_MODEL=Qwen/Qwen3-VL-30B-A3B-Instruct-FP8

# --- Product context scrape ---
OXYLABS_USERNAME=
OXYLABS_PASSWORD=
OXYLABS_AI_STUDIO_API_KEY=
OXYLABS_MODE=residential_proxy
OXYLABS_REALTIME_URL=https://realtime.oxylabs.io/v1/queries
OXYLABS_PROXY_URL=http://pr.oxylabs.io:7777
OXYLABS_PROXY_COUNTRY=US

# --- Voice (Nosana-hosted TTS endpoint) ---
NOSANA_API_KEY=
NOSANA_BASE_URL=https://dashboard.k8s.prd.nos.ci/api
NOSANA_TTS_URL=
NOSANA_TTS_BEARER_TOKEN=
TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign
TTS_LANGUAGE=English
TTS_TIMEOUT_SECONDS=120
